# App
APP_NAME=ACM-Talent-Bridge
ENV=dev
API_HOST=0.0.0.0
API_PORT=8000

# DB
DATABASE_URL=mysql+pymysql://acm:acm_pass@mysql:3306/acm_bridge?charset=utf8mb4

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Security (MVP: simple)
JWT_SECRET=change_me
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# OJ/Judge
JUDGE_DOCKER_IMAGE=acm-judge-runner:latest
JUDGE_TIME_LIMIT_MS=2000
JUDGE_MEMORY_LIMIT_MB=256
JUDGE_ENABLE_DOCKER=0

# Docker runner mode: bind (local dev) or volume (docker-compose worker)
JUDGE_DOCKER_MODE=volume
# When using volume mode in docker-compose, worker mounts judge_workspace to this path
JUDGE_WORKSPACE_DIR=/judge_workspace
JUDGE_WORKSPACE_VOLUME=judge_workspace


# AI (default mock)
AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=
